# Jimuqu Agent environment example
# 用法：
# 1. 复制为 .env
# 2. 修改必填项
# 3. 如需启用某个渠道，取消对应配置的注释或改成实际值

###############################################################################
# Runtime
###############################################################################

# 可选：运行时根目录。默认 runtime
# JIMUQU_RUNTIME_HOME=runtime

# 可选：上下文目录。默认 runtime/context
# JIMUQU_RUNTIME_CONTEXT_DIR=runtime/context

# 可选：skills 目录。默认 runtime/skills
# JIMUQU_RUNTIME_SKILLS_DIR=runtime/skills

# 可选：缓存目录。默认 runtime/cache
# JIMUQU_RUNTIME_CACHE_DIR=runtime/cache

# 可选：SQLite 状态库路径。默认 runtime/state.db
# JIMUQU_RUNTIME_STATE_DB=runtime/state.db

###############################################################################
# LLM - 必填
###############################################################################

# 必填：模型 provider，例如 openai-responses / openai / ollama / gemini / anthropic
JIMUQU_LLM_PROVIDER=

# 必填：模型 API 地址
JIMUQU_LLM_API_URL=

# 必填：模型名称
JIMUQU_LLM_MODEL=

# 必填：模型 API Key
JIMUQU_LLM_API_KEY=

# 可选：是否启用流式输出，默认 false
# JIMUQU_LLM_STREAM=false

# 可选：推理强度，默认 medium
# JIMUQU_LLM_REASONING_EFFORT=medium

# 可选：温度参数，默认 0.2
# JIMUQU_LLM_TEMPERATURE=0.2

# 可选：最大输出 token，默认 4096
# JIMUQU_LLM_MAX_TOKENS=4096

# 可选：上下文窗口 token，默认 128000
# JIMUQU_LLM_CONTEXT_WINDOW_TOKENS=128000

###############################################################################
# Scheduler / Compression / Learning / Rollback
###############################################################################

# 可选：是否启用定时调度，默认 true
# JIMUQU_SCHEDULER_ENABLED=true

# 可选：调度轮询秒数，默认 60
# JIMUQU_SCHEDULER_TICK_SECONDS=60

# 可选：是否启用自动压缩，默认 true
# JIMUQU_COMPRESSION_ENABLED=true

# 可选：压缩阈值比例，默认 0.5
# JIMUQU_COMPRESSION_THRESHOLD_PERCENT=0.5

# 可选：压缩摘要模型
# JIMUQU_COMPRESSION_SUMMARY_MODEL=

# 可选：压缩保护头部消息数量，默认 3
# JIMUQU_COMPRESSION_PROTECT_HEAD_MESSAGES=3

# 可选：压缩保留尾部比例，默认 0.2
# JIMUQU_COMPRESSION_TAIL_RATIO=0.2

# 可选：是否启用主回复后的自动学习，默认 true
# JIMUQU_LEARNING_ENABLED=true

# 可选：触发学习所需最少工具调用次数，默认 5
# JIMUQU_LEARNING_TOOL_CALL_THRESHOLD=5

# 可选：是否启用 rollback，默认 true
# JIMUQU_ROLLBACK_ENABLED=true

# 可选：每个来源保留的最大 checkpoint 数，默认 20
# JIMUQU_ROLLBACK_MAX_CHECKPOINTS_PER_SOURCE=20

###############################################################################
# Gateway authorization
###############################################################################

# 可选：全局允许用户列表，逗号分隔
# JIMUQU_GATEWAY_ALLOWED_USERS=

# 可选：是否允许所有用户访问，默认 false
# JIMUQU_GATEWAY_ALLOW_ALL_USERS=false

###############################################################################
# Weixin - 微信个人号
###############################################################################

# 如果要启用微信渠道，改成 true
# JIMUQU_WEIXIN_ENABLED=true

# 二选一：
# 1. 手动填写 accountId / token
# 2. 先留空，启动后在 dashboard 中扫码登录，系统会自动写回这两个值
JIMUQU_WEIXIN_ACCOUNT_ID=
JIMUQU_WEIXIN_TOKEN=

# 可选：微信私聊策略，默认 open
# 可选值：open / allowlist / disabled / pairing
# JIMUQU_WEIXIN_DM_POLICY=open

# 可选：微信群聊策略，默认 disabled
# 可选值：open / allowlist / disabled
# JIMUQU_WEIXIN_GROUP_POLICY=disabled

# 可选：微信允许用户列表，逗号分隔
# JIMUQU_WEIXIN_ALLOWED_USERS=

# 可选：微信群 allowlist，逗号分隔
# JIMUQU_WEIXIN_GROUP_ALLOWED_USERS=

# 可选：是否允许微信所有用户访问，默认 false
# JIMUQU_WEIXIN_ALLOW_ALL_USERS=false

# 可选：未授权私聊行为，默认 pair
# 可选值：pair / ignore
# JIMUQU_WEIXIN_UNAUTHORIZED_DM_BEHAVIOR=pair

# 可选：iLink API 地址
# JIMUQU_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# 可选：微信 CDN 地址
# JIMUQU_WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# 可选：长轮询地址。通常不需要单独设置
# JIMUQU_WEIXIN_LONG_POLL_URL=

# 可选：是否拆分多行消息，默认 false
# JIMUQU_WEIXIN_SPLIT_MULTILINE_MESSAGES=false

# 可选：分片发送间隔秒数，默认 0.35
# JIMUQU_WEIXIN_SEND_CHUNK_DELAY_SECONDS=0.35

# 可选：分片重试次数，默认 2
# JIMUQU_WEIXIN_SEND_CHUNK_RETRIES=2

# 可选：分片重试等待秒数，默认 1.0
# JIMUQU_WEIXIN_SEND_CHUNK_RETRY_DELAY_SECONDS=1.0

###############################################################################
# DingTalk - 钉钉
###############################################################################

# 如果要启用钉钉渠道，改成 true
# JIMUQU_DINGTALK_ENABLED=true

# 必填：钉钉 AppKey
# JIMUQU_DINGTALK_CLIENT_ID=

# 必填：钉钉 AppSecret
# JIMUQU_DINGTALK_CLIENT_SECRET=

# 必填：钉钉机器人编码
# JIMUQU_DINGTALK_ROBOT_CODE=

# 可选：钉钉私聊策略，默认 open
# JIMUQU_DINGTALK_DM_POLICY=open

# 可选：钉钉群聊策略，默认 open
# JIMUQU_DINGTALK_GROUP_POLICY=open

# 可选：钉钉允许用户列表，逗号分隔
# JIMUQU_DINGTALK_ALLOWED_USERS=

# 可选：钉钉群聊 allowlist，逗号分隔
# JIMUQU_DINGTALK_GROUP_ALLOWED_USERS=

# 可选：是否允许钉钉所有用户访问，默认 false
# JIMUQU_DINGTALK_ALLOW_ALL_USERS=false

# 可选：未授权私聊行为，默认 pair
# JIMUQU_DINGTALK_UNAUTHORIZED_DM_BEHAVIOR=pair

# 可选：Cool App Code
# JIMUQU_DINGTALK_COOL_APP_CODE=

# 可选：自定义 stream URL
# JIMUQU_DINGTALK_STREAM_URL=

###############################################################################
# Feishu - 飞书
###############################################################################

# 如果要启用飞书渠道，改成 true
# JIMUQU_FEISHU_ENABLED=true

# 必填：飞书 App ID
# JIMUQU_FEISHU_APP_ID=

# 必填：飞书 App Secret
# JIMUQU_FEISHU_APP_SECRET=

# 可选：飞书私聊策略，默认 open
# JIMUQU_FEISHU_DM_POLICY=open

# 可选：飞书群聊策略，默认 allowlist
# JIMUQU_FEISHU_GROUP_POLICY=allowlist

# 可选：飞书允许用户列表，逗号分隔
# JIMUQU_FEISHU_ALLOWED_USERS=

# 可选：飞书群聊 allowlist，逗号分隔
# JIMUQU_FEISHU_GROUP_ALLOWED_USERS=

# 可选：是否允许飞书所有用户访问，默认 false
# JIMUQU_FEISHU_ALLOW_ALL_USERS=false

# 可选：未授权私聊行为，默认 pair
# JIMUQU_FEISHU_UNAUTHORIZED_DM_BEHAVIOR=pair

# 可选：自定义 websocket URL
# JIMUQU_FEISHU_WEBSOCKET_URL=

# 可选：显式指定 bot Open ID / User ID / 名称
# 不配置时系统会尝试通过官方接口自动发现
# JIMUQU_FEISHU_BOT_OPEN_ID=
# JIMUQU_FEISHU_BOT_USER_ID=
# JIMUQU_FEISHU_BOT_NAME=

###############################################################################
# WeCom - 企业微信 Bot
###############################################################################

# 如果要启用企微渠道，改成 true
# JIMUQU_WECOM_ENABLED=true

# 必填：企微机器人 ID
# JIMUQU_WECOM_BOT_ID=

# 必填：企微机器人 Secret
# JIMUQU_WECOM_SECRET=

# 可选：企微私聊策略，默认 open
# JIMUQU_WECOM_DM_POLICY=open

# 可选：企微群聊策略，默认 open
# JIMUQU_WECOM_GROUP_POLICY=open

# 可选：企微允许用户列表，逗号分隔
# JIMUQU_WECOM_ALLOWED_USERS=

# 可选：企微群聊 allowlist，逗号分隔
# JIMUQU_WECOM_GROUP_ALLOWED_USERS=

# 可选：是否允许企微所有用户访问，默认 false
# JIMUQU_WECOM_ALLOW_ALL_USERS=false

# 可选：未授权私聊行为，默认 pair
# JIMUQU_WECOM_UNAUTHORIZED_DM_BEHAVIOR=pair

# 可选：自定义 websocket URL
# JIMUQU_WECOM_WEBSOCKET_URL=

# 可选：企微按群成员 allowlist，使用 JSON
# 示例：{"room-a":["alice","bob"],"*":["admin"]}
# JIMUQU_WECOM_GROUP_MEMBER_ALLOW_MAP_JSON=

###############################################################################
# Optional tools / integrations
###############################################################################

# 可选：PDF 生成用中文字体路径
# JIMUQU_PDF_FONT_PATH=

# 可选：Skills Hub 使用的 GitHub Token
# GITHUB_TOKEN=

# 可选：GitHub CLI Token
# GH_TOKEN=

# 可选：GitHub App ID
# GITHUB_APP_ID=

# 可选：GitHub App 私钥路径
# GITHUB_APP_PRIVATE_KEY_PATH=

# 可选：GitHub App 安装 ID
# GITHUB_APP_INSTALLATION_ID=
